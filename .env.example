REZ_BACKEND_PORT=3001
REZ_REQUEST_BODY_LIMIT=64kb
REZ_MAX_MESSAGE_CHARS=8000

# Comma-separated frontend origins. Leave empty to allow all origins in local dev.
REZ_CORS_ALLOWLIST=http://localhost:5173,http://127.0.0.1:5173

# Provider base URLs
REZ_PROVIDER_LMSTUDIO_BASE_URL=http://127.0.0.1:1234/v1
REZ_PROVIDER_OLLAMA_BASE_URL=http://127.0.0.1:11434

# Optional provider/model defaults
REZ_PROVIDER=lmstudio
REZ_MODEL=
LMSTUDIO_MODEL=qwen2.5-coder-14b-instruct
OLLAMA_MODEL=llama3.2:latest
REZ_FEATURE_FLAGS=

# Optional auth scaffold (Phase 5 Step 3)
SUPABASE_URL=
SUPABASE_ANON_KEY=
